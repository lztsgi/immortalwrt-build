config amlogic 'config'
	# [系统] 开启 Amlogic 插件与在线更新功能 (1=开启, 0=关闭)
	option enable '1'
	
	# 原精简版本在线更新地址 https://github.com/nantayo/N1-OpenWrt/releases
	# [更新] 指定在线拉取固件的 GitHub 仓库地址
	option amlogic_firmware_repo 'https://github.com/lztsgi/immortalwrt-build'
	
	# 原 OpenWrt_
	# [更新] 匹配 Release 固件包时的文件命名前缀
	option amlogic_firmware_tag 'N1_OpenWrt_'
	
	# [更新] 指定固件包的后缀格式，用于精准识别下载文件
	option amlogic_firmware_suffix '.img.xz'
	
	#  breakingbadboy 的 kernel releases 分支 https://github.com/breakingbadboy/OpenWrt
	# [更新] 指定在线拉取独立内核的 GitHub 仓库地址
	option amlogic_kernel_path 'https://github.com/ophub/kernel'
	
	# 推荐留空，默认跟随当前固件分支；不要再写死 6.12.y
	# [更新] 指定需要拉取的内核分支（留空则脚本自动识别当前匹配版本）
	option amlogic_kernel_branch ''
	
	# [刷写] 升级固件时是否保留当前系统配置 (1=保留, 0=不保留/全新安装)
	option amlogic_firmware_config '1'
	
	# [刷写] 升级时是否将 Bootloader 引导程序一并写入 (1=写入, 0=跳过)
	option amlogic_write_bootloader '1'
	
	# [系统] 设定共享挂载分区的文件系统格式 (通常为 ext4 或 btrfs)
	option amlogic_shared_fstype 'ext4'

config settings 'armcpu'
	# [CPU] 核心调度器策略 (performance=锁定最高频性能模式; schedutil=按需动态调频)
	option governor0 'performance'
	
	# [CPU] CPU 最低运行频率（单位：kHz，1512000 即 1.512 GHz）
	option minfreq0 '1512000'
	
	# [CPU] CPU 最高运行频率（单位：kHz）
	option maxfreq0 '1512000'
